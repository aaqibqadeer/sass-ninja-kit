# =============================================================================
# ninjakit — TEST environment variables (CLAUDE.md §12)
# Copy to .env.test and point it at an ISOLATED test instance — never the same
# database/project as production or local dev. Agents default to these creds
# for any "test this" / destructive operation.
#
# When TEST_MODE=true, config/env.schema.ts requires the DB target to match
# TEST_DB_PATTERN (default /test/i), or it refuses to boot.
# =============================================================================

# Must be true so the boot-time test guardrail is enforced.
TEST_MODE=true
# TEST_DB_PATTERN=test              # case-insensitive regex the DB target must match

# --- Test database (required) ------------------------------------------------
# Use a dedicated test instance whose target matches TEST_DB_PATTERN:
#   Supabase: create a separate project at https://supabase.com/dashboard —
#             give the project ref a `-test` marker so the URL matches.
#   MongoDB:  create a separate free M0 cluster at https://cloud.mongodb.com,
#             or a `*-test` database name locally.
DB_PROVIDER=supabase                 # supabase | mongodb
# Supabase (test project only):
# SUPABASE_URL=https://<ref>-test.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# MongoDB (test cluster/db only):
# MONGODB_URI=mongodb://localhost:27017/ninjakit-test

# --- Provider test keys (later phases) ---------------------------------------
# Use sandbox/test-mode keys only (e.g. Stripe test keys, Twilio test creds).
# STRIPE_SECRET_KEY=    # (later phase) sk_test_...
# RESEND_API_KEY=       # (later phase) test key
# TWILIO_ACCOUNT_SID=   # (later phase) test creds
