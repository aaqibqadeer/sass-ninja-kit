# =============================================================================
# ninjakit — TEST environment variables (CLAUDE.md §12)
# Copy to .env.test and point it at an ISOLATED test instance — never the same
# database/project as production or local dev. Agents default to these creds
# for any "test this" / destructive operation.
#
# When TEST_MODE=true, config/env.schema.ts enforces a guardrail (Phase 2) that
# refuses to boot unless the DB target matches an allow-listed *test* pattern.
# =============================================================================

# Must be true so the boot-time test guardrail is enforced.
TEST_MODE=true

# --- Test database (Phase 2) -------------------------------------------------
# Use a dedicated free-tier test instance:
#   Supabase: create a separate project at https://supabase.com/dashboard — its
#             project ref must match the test allow-list (e.g. a `-test` suffix
#             or an agreed ref prefix defined in Phase 2).
#   MongoDB:  create a separate free M0 cluster at
#             https://cloud.mongodb.com — name it with a `-test` suffix.
# DB_PROVIDER=          # supabase | mongodb
# DATABASE_URL=         # (Phase 2) test instance only
# SUPABASE_URL=         # (Phase 2) test project only
# SUPABASE_ANON_KEY=    # (Phase 2)
# SUPABASE_SERVICE_ROLE_KEY=  # (Phase 2)
# MONGODB_URI=          # (Phase 2) test cluster only

# --- Provider test keys (later phases) ---------------------------------------
# Use sandbox/test-mode keys only (e.g. Stripe test keys, Twilio test creds).
# STRIPE_SECRET_KEY=    # (later phase) sk_test_...
# RESEND_API_KEY=       # (later phase) test key
# TWILIO_ACCOUNT_SID=   # (later phase) test creds
