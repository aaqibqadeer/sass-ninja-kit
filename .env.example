# =============================================================================
# ninjakit — environment variables
# Copy to .env.local and fill in values for the features you enable.
#
# HOW FLAGS WORK (config/features.ts): a feature is ON when its
# NEXT_PUBLIC_FEATURE_* var is present and non-empty (resolved via
# !!process.env.X). To ENABLE, uncomment/set the toggle (e.g. =1). To DISABLE,
# leave it commented out. ⚠︎ ANY non-empty value enables it — including "0" or
# "false" — so disable by removing the line, not by setting it to false.
#
# Each toggle unlocks provider SECRET(s) that become REQUIRED at boot when the
# flag is on (validated in config/env.schema.ts). Secrets are server-only.
# =============================================================================

# --- Core --------------------------------------------------------------------
# NODE_ENV is set by the runtime (development | test | production).
# Base URL — used to build OAuth redirect URIs and auth email links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Bypass env validation for builds/CI without real secrets (never at runtime).
# SKIP_ENV_VALIDATION=1

# --- Test environment guardrail (§12) ----------------------------------------
# When true, config/env.schema.ts requires the DB target (SUPABASE_URL /
# MONGODB_URI) to match TEST_DB_PATTERN, or it refuses to boot.
# TEST_MODE=false
# TEST_DB_PATTERN=test              # case-insensitive regex the DB target must match

# =============================================================================
# FEATURE FLAGS  (toggles — uncomment to enable)
# =============================================================================

# --- Auth --------------------------------------------------------------------
# Enable one or more sign-in methods. Any auth method requires AUTH_SECRET.
# NEXT_PUBLIC_FEATURE_AUTH_EMAIL_PASSWORD=1
# NEXT_PUBLIC_FEATURE_AUTH_MAGIC_LINK=1
# NEXT_PUBLIC_FEATURE_AUTH_OAUTH_GOOGLE=1
# NEXT_PUBLIC_FEATURE_AUTH_OAUTH_GITHUB=1
#
# Required when ANY auth method is on:
# AUTH_SECRET=                       # random 32+ char secret (signs custom-flow JWTs)
# Required when auth.magicLink is on (email delivery, MongoDB flow):
# RESEND_API_KEY=
# AUTH_EMAIL_FROM=                   # from-address for auth emails (defaults to Resend sandbox)
# Required when auth.oauth.google is on:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Required when auth.oauth.github is on:
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# --- Roles & super admin (§14) -----------------------------------------------
# Platform super-admin is a flag on the user record, independent of org roles and
# of multi-tenancy. `pnpm seed` promotes this user (falls back to the seeded
# admin when unset). Optional — unlocks no secret.
# SUPER_ADMIN_EMAIL=you@example.com

# --- Payments (Stripe) -------------------------------------------------------
# NEXT_PUBLIC_FEATURE_PAYMENTS=1
# Optional cadence sub-flag — when on, plans expose annual pricing + discount and
# checkout offers a monthly/annual toggle. Unlocks no extra secret. (§15)
# NEXT_PUBLIC_FEATURE_PAYMENTS_ANNUAL_BILLING=1
# Required when payments is on:
# STRIPE_SECRET_KEY=                 # sk_live_... / sk_test_...
# STRIPE_WEBHOOK_SECRET=             # whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=# pk_live_... / pk_test_... (client-side)

# --- Storage (S3 / S3-compatible) --------------------------------------------
# NEXT_PUBLIC_FEATURE_STORAGE=1
# Required when storage is on:
# STORAGE_PROVIDER=s3                # s3 (only provider shipped)
# Required when STORAGE_PROVIDER=s3:
# AWS_S3_BUCKET=
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Optional — custom endpoint for S3-compatible providers (Cloudflare R2, MinIO):
# AWS_S3_ENDPOINT=

# --- Phone verification (Twilio Verify) --------------------------------------
# NEXT_PUBLIC_FEATURE_PHONE_VERIFICATION=1
# Required when phoneVerification is on:
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=

# --- Admin panel -------------------------------------------------------------
# NEXT_PUBLIC_FEATURE_ADMIN=1        # no extra secret required

# --- AI providers ------------------------------------------------------------
# Comma-separated list of enabled providers (anthropic, openai). Empty = off.
# NEXT_PUBLIC_FEATURE_AI_PROVIDERS=anthropic,openai
# Required per provider listed above:
# ANTHROPIC_API_KEY=                 # when list includes 'anthropic'
# OPENAI_API_KEY=                    # when list includes 'openai'
# Optional: preferred default provider when several are enabled (anthropic|openai).
# Falls back to the first enabled provider when unset.
# AI_DEFAULT_PROVIDER=anthropic

# --- Cookie consent ----------------------------------------------------------
# Renders a flag-gated accept/reject banner; the choice is stored in a cookie
# (ninjakit_cookie_consent). No extra secret required. See docs/legal-templates/.
# NEXT_PUBLIC_FEATURE_COOKIE_BANNER=1

# --- Multi-tenancy -----------------------------------------------------------
# Off = single silent default org per user (no org UI). On = org switching/invites.
# The schema is ALWAYS multi-tenant regardless of this flag. Email invites reuse
# RESEND_API_KEY (above); without it, invite links are logged to the server
# console in dev. See docs/guides/multi-tenancy.md.
# NEXT_PUBLIC_FEATURE_MULTI_TENANT=1

# =============================================================================
# DATABASE (CORE — DB_PROVIDER is always required)
# Pick one provider. See docs/guides/choosing-database.md.
# =============================================================================
DB_PROVIDER=supabase                 # supabase | mongodb
#
# Required when DB_PROVIDER=supabase:
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=         # server-only (used by adapter + seed)
#
# Required when DB_PROVIDER=mongodb:
# MONGODB_URI=mongodb://localhost:27017/ninjakit
