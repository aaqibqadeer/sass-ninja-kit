# =============================================================================
# ninjakit — environment variables
# Copy to .env.local and fill in values for the features you enable.
#
# HOW FLAGS WORK (config/features.ts): a feature is ON when its
# NEXT_PUBLIC_FEATURE_* var is present and non-empty (resolved via
# !!process.env.X). To ENABLE, uncomment/set the toggle (e.g. =1). To DISABLE,
# leave it commented out. ⚠︎ ANY non-empty value enables it — including "0" or
# "false" — so disable by removing the line, not by setting it to false.
#
# Each toggle unlocks provider SECRET(s) that become REQUIRED at boot when the
# flag is on (validated in config/env.schema.ts). Secrets are server-only.
# =============================================================================

# --- Core --------------------------------------------------------------------
# NODE_ENV is set by the runtime (development | test | production).

# --- Test environment guardrail (§12) ----------------------------------------
# When true, config/env.schema.ts enforces the test-DB allow-list guardrail.
# TEST_MODE=false

# =============================================================================
# FEATURE FLAGS  (toggles — uncomment to enable)
# =============================================================================

# --- Auth --------------------------------------------------------------------
# Enable one or more sign-in methods. Any auth method requires AUTH_SECRET.
# NEXT_PUBLIC_FEATURE_AUTH_EMAIL_PASSWORD=1
# NEXT_PUBLIC_FEATURE_AUTH_MAGIC_LINK=1
# NEXT_PUBLIC_FEATURE_AUTH_OAUTH_GOOGLE=1
# NEXT_PUBLIC_FEATURE_AUTH_OAUTH_GITHUB=1
#
# Required when ANY auth method is on:
# AUTH_SECRET=                       # random 32+ char secret
# Required when auth.magicLink is on (email delivery):
# RESEND_API_KEY=
# Required when auth.oauth.google is on:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Required when auth.oauth.github is on:
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# --- Payments (Stripe) -------------------------------------------------------
# NEXT_PUBLIC_FEATURE_PAYMENTS=1
# Required when payments is on:
# STRIPE_SECRET_KEY=                 # sk_live_... / sk_test_...
# STRIPE_WEBHOOK_SECRET=             # whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=# pk_live_... / pk_test_... (client-side)

# --- Storage -----------------------------------------------------------------
# NEXT_PUBLIC_FEATURE_STORAGE=1
# Required when storage is on:
# STORAGE_PROVIDER=                  # e.g. supabase | s3 (bucket/keys added with the adapter)

# --- Phone verification (Twilio Verify) --------------------------------------
# NEXT_PUBLIC_FEATURE_PHONE_VERIFICATION=1
# Required when phoneVerification is on:
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=

# --- Admin panel -------------------------------------------------------------
# NEXT_PUBLIC_FEATURE_ADMIN=1        # no extra secret required

# --- AI providers ------------------------------------------------------------
# Comma-separated list of enabled providers (anthropic, openai). Empty = off.
# NEXT_PUBLIC_FEATURE_AI_PROVIDERS=anthropic,openai
# Required per provider listed above:
# ANTHROPIC_API_KEY=                 # when list includes 'anthropic'
# OPENAI_API_KEY=                    # when list includes 'openai'

# --- Multi-tenancy -----------------------------------------------------------
# Off = single silent default org per user (no org UI). On = org switching/invites.
# The schema is ALWAYS multi-tenant regardless of this flag.
# NEXT_PUBLIC_FEATURE_MULTI_TENANT=1

# =============================================================================
# DATABASE (Phase 2 — not wired to a Phase 1 flag yet)
# =============================================================================
# DB_PROVIDER=          # supabase | mongodb (chosen once at init)
# DATABASE_URL=         # (Phase 2)
# SUPABASE_URL=         # (Phase 2, if DB_PROVIDER=supabase)
# SUPABASE_ANON_KEY=    # (Phase 2)
# SUPABASE_SERVICE_ROLE_KEY=  # (Phase 2, server-only)
# MONGODB_URI=          # (Phase 2, if DB_PROVIDER=mongodb)
