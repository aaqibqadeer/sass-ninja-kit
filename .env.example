# =============================================================================
# ninjakit — environment variables
# Copy to .env.local and fill in values for the flags/features you enable.
# Every var is validated in config/env.schema.ts. Vars are grouped by feature
# and added per phase; placeholders below name what each later phase will need.
# =============================================================================

# --- Core --------------------------------------------------------------------
# NODE_ENV is set by the runtime (development | test | production).

# --- Test environment guardrail (Phase 0.5, §12) -----------------------------
# When true, config/env.schema.ts enforces the test-DB allow-list guardrail.
# TEST_MODE=false

# --- Feature flags (config/features.ts) --------------------------------------
# Each optional feature is toggled by a flag resolved from an env var here.
# Flags are added as each phase introduces the feature it gates.
# NEXT_PUBLIC_FEATURE_...=   # (added per phase)

# --- Database (Phase 2) ------------------------------------------------------
# DB_PROVIDER=          # supabase | mongodb (chosen once at init)
# DATABASE_URL=         # (Phase 2)
# SUPABASE_URL=         # (Phase 2, if DB_PROVIDER=supabase)
# SUPABASE_ANON_KEY=    # (Phase 2, if DB_PROVIDER=supabase)
# SUPABASE_SERVICE_ROLE_KEY=  # (Phase 2, server-only)
# MONGODB_URI=          # (Phase 2, if DB_PROVIDER=mongodb)

# --- Auth (later phase) ------------------------------------------------------
# AUTH_SECRET=          # (later phase)
# GOOGLE_CLIENT_ID=     # (later phase, if OAuth flag on)
# GOOGLE_CLIENT_SECRET= # (later phase)

# --- Storage (later phase) ---------------------------------------------------
# STORAGE_PROVIDER=     # (later phase)

# --- Email (later phase) -----------------------------------------------------
# EMAIL_PROVIDER=       # (later phase)
# RESEND_API_KEY=       # (later phase, if email flag on)

# --- Phone verification (later phase) ----------------------------------------
# PHONE_PROVIDER=       # (later phase)
# TWILIO_ACCOUNT_SID=   # (later phase, if phone flag on)
# TWILIO_AUTH_TOKEN=    # (later phase)

# --- Payments (later phase) --------------------------------------------------
# STRIPE_SECRET_KEY=    # (later phase, if payments flag on)
# STRIPE_WEBHOOK_SECRET=# (later phase)

# --- AI providers (later phase) ----------------------------------------------
# AI_PROVIDER=          # (later phase)
# ANTHROPIC_API_KEY=    # (later phase, if AI flag on)
# OPENAI_API_KEY=       # (later phase, if AI flag on)
